# UAE Threat Tracker - API Keys Configuration
# Copy this file to .env and fill in your keys
# NEVER commit .env to git

# NewsAPI (free at newsapi.org - register for key)
VITE_NEWSAPI_KEY=your_newsapi_key_here

# ACLED (free at acleddata.com - register for key)
VITE_ACLED_KEY=your_acled_key_here
VITE_ACLED_EMAIL=your_email_here

# MediaStack (free at mediastack.com - register)
VITE_MEDIASTACK_KEY=your_mediastack_key_here

# GDELT needs no API key - always active
